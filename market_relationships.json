    "symbol_conventions": {
      "summary": [
        "Perps symbols are usually plain symbols like BTC-USD or ETH-USD.",
        "Spot symbols often use wrapped or venue-style prefixes such as v, for example vBTC_vUSDC.",
        "Do not assume every asset follows the same prefix pattern; verify with the live /markets/symbols endpoint when possible."
      ],
      "perps_pattern_examples": [
        {
          "input_asset": "BTC",
          "sodex_symbol": "BTC-USD",
          "notes": "Perps pair format is typically BASE-USD."
        },
        {
          "input_asset": "ETH",
          "sodex_symbol": "ETH-USD",
          "notes": "Perps pair format is typically BASE-USD."
        }
      ],
      "spot_pattern_examples": [
        {
          "input_asset": "BTC",
          "base_coin": "vBTC",
          "quote_coin": "vUSDC",
          "sodex_symbol": "vBTC_vUSDC",
          "notes": "Spot pair format commonly looks like BASE_QUOTE, with wrapped asset prefixes such as v."
        },
        {
          "input_asset": "ETH",
          "base_coin": "vETH",
          "quote_coin": "vUSDC",
          "sodex_symbol": "vETH_vUSDC",
          "notes": "Spot pair format commonly looks like BASE_QUOTE, with wrapped asset prefixes such as v."
        }
      ],
      "prefix_hints": {
        "v": "Often used for wrapped or venue-native spot assets and quote assets, such as vBTC or vUSDC.",
        "w": "May be used by some ecosystems or wrapped-token naming conventions, but do not infer blindly without checking the live symbol list."
      },
      "translation_rules_for_antigravity": [
        "If market type is perps, try BASE-USD first.",
        "If market type is spot, try vBASE_vUSDC first for major assets.",
        "If the exact symbol is unknown, fetch the live symbols list and match by normalized asset name before building the kline URL.",
        "Normalized matching should ignore separators and compare plain asset names like BTC, ETH, SOL, XRP, and quote hints like USDC or USD."
      ],
      "fallback_discovery": {
        "perps_symbols_endpoint": "https://mainnet-gw.sodex.dev/api/v1/perps/markets/symbols",
        "spot_symbols_endpoint": "https://mainnet-gw.sodex.dev/api/v1/spot/markets/symbols"
      }
